# EmailJS - OTP verification
# Get these from https://dashboard.emailjs.com/
# 1. Create an account, add an Email Service (Gmail, Outlook, etc.)
# 2. Create a template with variables: {{to_email}} and {{otp}}
#    - Set "To" field to {{to_email}} or use a fixed test email
#    - Body: "Your TatheerApp OTP is: {{otp}}"
# 3. Enable "Allow API requests" in Account > Security
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key

# Dev only: log OTP to console instead of sending (when EmailJS not configured)
# DEV_OTP=true
